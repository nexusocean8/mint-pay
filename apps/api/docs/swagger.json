            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessTokenResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "Admin user already registered"
          }
        },
        "summary": "Register admin user",
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/auth/login": {
      "post": {
