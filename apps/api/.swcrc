{
  "$schema": "https://json.schemastore.org/swcrc",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "baseUrl": ".",
    "paths": {
      "@mint-pay/types": ["../../packages/types/index.ts"]
    },
    "target": "es2021"
  },
  "module": {
    "type": "commonjs"
  }
}