# --- App ---
NODE_ENV=production                   # → App: NODE_ENV
PORT=8080
API_KEY=                              # → App: MONERO_API_KEY (X-Api-Key for merchant endpoints)
ADMIN_API_KEY=                        # X-Admin-Api-Key for admin/dashboard endpoints

# --- Mongo ---
MONGO_URI=                            # → App: MONGODB_URI
MONGO_DB_NAME=monero_payments

# --- Monero network ---
MONERO_NETWORK=stagenet

# --- monerod ---
MONERO_DAEMON_URI=
MONERO_DAEMON_USER=
MONERO_DAEMON_PASSWORD=

# --- Wallet (view-only, in-process MoneroWalletFull) ---
MONERO_WALLET_PATH=./data/wallet/merchant
MONERO_VIEW_KEY=
MONERO_PRIMARY_ADDRESS=
MONERO_RESTORE_HEIGHT=
MONERO_PREWARM_SYNC=false

# --- Pricing ---
RATE_PROVIDER=cmc
CMC_API_KEY=                          # → App: COINMARKETCAP_API_KEY
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# --- Webhooks ---
WEBHOOK_SIGNING_SECRET=               # → App: MINT_WEBHOOK_SECRET (must match)

# --- Tunable defaults ---
CONFIRMATION_DEPTH=1
INVOICE_DEFAULT_EXPIRY_SEC=1200
INVOICE_MAX_EXPIRY_SEC=1800
SCANNER_INTERVAL_MS=10000
SCANNER_LOCK_TTL_MS=30000
MONERO_SYNCED_THRESHOLD_BLOCKS=2
MONERO_PREWARM_SYNC=true
RATE_CACHE_TTL_MS=45000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_DISPATCH_INTERVAL_MS=5000
WEBHOOK_TIMEOUT_MS=10000