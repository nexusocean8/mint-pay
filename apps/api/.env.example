# --- App ---
NODE_ENV=                   # → App: NODE_ENV
PORT=
API_KEY=                              # → App: MONERO_API_KEY (X-Api-Key for merchant endpoints)
ADMIN_API_KEY=                        # X-Admin-Api-Key for admin/dashboard endpoints

# --- Mongo ---
MONGO_URI=                            # → App: MONGODB_URI
MONGO_DB_NAME=

# --- Monero network ---
MONERO_NETWORK=

# --- monerod ---
MONERO_DAEMON_URI=
MONERO_DAEMON_USER=
MONERO_DAEMON_PASSWORD=

# --- firod ---

FIRO_CONFIRMATION_DEPTH=
FIRO_RPC_HOST=
FIRO_RPC_PORT=
FIRO_RPC_USER=
FIRO_RPC_PASS=
FIRO_RPC_PROTOCOL=

# --- Wallet (view-only, in-process MoneroWalletFull) ---
MONERO_WALLET_PATH=
MONERO_VIEW_KEY=
MONERO_PRIMARY_ADDRESS=
MONERO_RESTORE_HEIGHT=
MONERO_PREWARM_SYNC=

# --- Pricing ---
RATE_PROVIDER=cmc
CMC_API_KEY=                          # → App: COINMARKETCAP_API_KEY
CMC_BASE_URL=

# --- Webhooks ---
WEBHOOK_SIGNING_SECRET=               # → App: MINT_WEBHOOK_SECRET (must match)

# --- Tunable defaults ---
CONFIRMATION_DEPTH=
INVOICE_DEFAULT_EXPIRY_SEC=
INVOICE_MAX_EXPIRY_SEC=
SCANNER_INTERVAL_MS=
SCANNER_LOCK_TTL_MS=
MONERO_SYNCED_THRESHOLD_BLOCKS=
MONERO_PREWARM_SYNC=
RATE_CACHE_TTL_MS=
WEBHOOK_MAX_ATTEMPTS=
WEBHOOK_DISPATCH_INTERVAL_MS=
WEBHOOK_TIMEOUT_MS=
