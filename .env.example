# =============================================================================
# Production Environment
# =============================================================================

# --- App ---
NODE_ENV=production
ENABLED_CHAINS=                       # comma-separated: xmr, firo, or xmr,firo

# --- Frontend ---
NEXT_TELEMETRY_DISABLED=1
JWT_SECRET=                           # must match API JWT_SECRET
MINT_API_URL=                         # e.g. http://mint_api:8080/v1
MINT_ADMIN_KEY=                       # must match ADMIN_API_KEY
MINT_API_KEY=                         # must match API_KEY

# --- API auth ---
API_KEY=                              # X-Api-Key for merchant endpoints (≥16 chars)
ADMIN_API_KEY=                        # X-Admin-Api-Key for admin endpoints (≥16 chars)

# --- Mongo ---
MONGO_URI=mongodb://admin:password@mint_mongo:27017
MONGO_DB_NAME=mint_dev
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_INITDB_DATABASE=mint_dev

# --- Monero ---
MONERO_NETWORK=stagenet
MONERO_DAEMON_URI=http://monerod:38081
MONERO_DAEMON_USER=
MONERO_DAEMON_PASSWORD=
MONERO_RPC_LOGIN=                     # user:password (used by compose --rpc-login flag)
MONERO_WALLET_PATH=./data/wallet/merchant
MONERO_VIEW_KEY=                      # 64 hex chars (first boot only)
MONERO_PRIMARY_ADDRESS=               # first boot only
MONERO_RESTORE_HEIGHT=2142513
MONERO_PREWARM_SYNC=false

# --- Firo ---
FIRO_RPC_HOST=firod
FIRO_RPC_PORT=8888
FIRO_RPC_USER=
FIRO_RPC_PASS=
FIRO_RPC_PROTOCOL=http

# --- Pricing ---
RATE_PROVIDER=cmc
CMC_API_KEY=
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# --- Webhooks ---
WEBHOOK_SIGNING_SECRET=

# --- Tunable settings ---
CONFIRMATION_DEPTH=1
INVOICE_DEFAULT_EXPIRY_SEC=3600
INVOICE_MAX_EXPIRY_SEC=7200
SCANNER_INTERVAL_MS=10000
SCANNER_LOCK_TTL_MS=30000
MONERO_SYNCED_THRESHOLD_BLOCKS=2
RATE_CACHE_TTL_MS=45000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_DISPATCH_INTERVAL_MS=5000
WEBHOOK_TIMEOUT_MS=10000